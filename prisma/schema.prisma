// ITForge — Prisma Schema
// Conventions: @map / @@map for snake_case in DB, camelCase in code
// Every table: id (UUID), createdAt, updatedAt
// Soft deletes: deletedAt DateTime?
// Multi-tenant: organizationId on every business entity

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PermissionModule {
  DEVELOPMENT
  INFRASTRUCTURE
  SUPPORT
  SYSTEM

  @@map("permission_module")
}

enum ControlLevel {
  LEVEL_0
  LEVEL_1
  LEVEL_2
  LEVEL_3

  @@map("control_level")
}

enum DeploymentType {
  WEB
  DESKTOP
  SERVICE
  MOBILE

  @@map("deployment_type")
}

enum ProjectStatus {
  IDEA
  PLANNING
  DEVELOPMENT
  QA
  PRODUCTION
  SUSPENDED
  DISCONTINUED

  @@map("project_status")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("priority")
}

enum EnvironmentType {
  DEV
  STAGING
  PRODUCTION

  @@map("environment_type")
}

enum CredentialType {
  DATABASE
  SSH
  API_KEY
  ADMIN_ACCESS
  OTHER

  @@map("credential_type")
}

enum TechStackCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE_ENGINE
  TOOL
  OTHER

  @@map("tech_stack_category")
}

enum ProjectRelationType {
  DEPENDS_ON
  EXTENDS
  REPLACES
  SHARES_DATABASE

  @@map("project_relation_type")
}

enum DocumentType {
  SCREENSHOT
  TECHNICAL_DOC
  USER_MANUAL
  ARCHITECTURE_DIAGRAM
  CONFIG_FILE
  OTHER

  @@map("document_type")
}

enum ChangeRequestType {
  NEW_FEATURE
  MODIFICATION
  BUG_FIX
  DATA_CORRECTION
  REPORT
  VISUAL_CHANGE
  OTHER

  @@map("change_request_type")
}

enum ChangeRequestStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("change_request_status")
}

enum DatabaseEngine {
  POSTGRESQL
  MYSQL
  SQL_SERVER
  MONGODB
  SQLITE
  OTHER

  @@map("database_engine")
}

enum DatabaseManagedBy {
  DBA_TEAM
  DEV_TEAM
  EXTERNAL

  @@map("database_managed_by")
}

// ─── Organization (top-level tenant) ─────────────────────────────────────────

model Organization {
  id             String  @id @default(uuid())
  name           String
  slug           String  @unique
  tagline        String?
  logoPath       String? @map("logo_path")
  primaryColor   String? @map("primary_color")
  secondaryColor String? @map("secondary_color")
  accentColor    String? @map("accent_color")
  faviconPath    String? @map("favicon_path")
  terminology    Json?
  config         Json?

  // Feature flags
  developmentEnabled    Boolean @default(true)  @map("development_enabled")
  infrastructureEnabled Boolean @default(false) @map("infrastructure_enabled")
  supportEnabled        Boolean @default(false) @map("support_enabled")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  users            User[]
  roles            Role[]
  sessions         Session[]
  departments      Department[]
  resources        Resource[]
  projects         Project[]
  databases        Database[]
  serverGroups     ServerGroup[]
  servers          Server[]
  networkEquipment NetworkEquipment[]
  domains          Domain[]
  assets           Asset[]
  supportTickets   SupportTicket[]
  userAccounts     UserAccount[]

  @@map("organizations")
}

// ─── Department ───────────────────────────────────────────────────────────────

model Department {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  code           String  @map("code")
  parentId       String? @map("parent_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  parent       Department?   @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children     Department[]  @relation("DepartmentHierarchy")
  users        User[]
  usages       DepartmentUsage[]
  changeRequests ChangeRequest[]
  assets           Asset[]
  supportTickets   SupportTicket[]
  userAccounts     UserAccount[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  departmentId   String? @map("department_id")
  email          String
  passwordHash   String  @map("password_hash")
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  isActive       Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization            Organization             @relation(fields: [organizationId], references: [id])
  department              Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  sessions                Session[]
  userRoles               UserRole[]
  userPermissionOverrides UserPermissionOverride[]
  loginAttempts           LoginAttempt[]
  auditLogs               AuditLog[]
  responsibleProjects     Project[]                @relation("ProjectResponsible")
  assignedChangeRequests  ChangeRequest[]          @relation("ChangeRequestAssignee")
  requestedChangeRequests ChangeRequest[]          @relation("ChangeRequestRequester")
  changeRequestComments   ChangeRequestComment[]
  uploadedDocuments       ProjectDocument[]
  uploadedAttachments     ChangeRequestAttachment[]
  uploadedServerDocuments ServerDocument[]
  assignedTickets       SupportTicket[]   @relation("TicketAssignee")
  ticketComments        SupportTicketComment[]
  uploadedTicketFiles   SupportTicketAttachment[]
  performedMaintenance  MaintenanceLog[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model Session {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  expiresAt      DateTime @map("expires_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model LoginAttempt {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  email      String
  ipAddress  String   @map("ip_address")
  successful Boolean
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([ipAddress])
  @@map("login_attempts")
}

// ─── RBAC ─────────────────────────────────────────────────────────────────────

model Resource {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  code           String           @unique
  name           String
  module         PermissionModule
  sortOrder      Int              @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  resourceActions ResourceAction[]

  @@index([module])
  @@map("resources")
}

model Action {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  isUniversal Boolean @default(false) @map("is_universal")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  resourceActions ResourceAction[]

  @@map("actions")
}

model ResourceAction {
  id         String @id @default(uuid())
  resourceId String @map("resource_id")
  actionId   String @map("action_id")

  createdAt DateTime @default(now()) @map("created_at")

  resource               Resource                 @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  action                 Action                   @relation(fields: [actionId], references: [id], onDelete: Cascade)
  rolePermissions        RolePermission[]
  userPermissionOverrides UserPermissionOverride[]

  @@unique([resourceId, actionId])
  @@map("resource_actions")
}

model Role {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?
  isSystem       Boolean @default(false) @map("is_system")
  isDefault      Boolean @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization    Organization     @relation(fields: [organizationId], references: [id])
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model UserRole {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roleId String @map("role_id")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id               String  @id @default(uuid())
  roleId           String  @map("role_id")
  resourceActionId String  @map("resource_action_id")
  allowed          Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  role           Role           @relation(fields: [roleId], references: [id], onDelete: Cascade)
  resourceAction ResourceAction @relation(fields: [resourceActionId], references: [id], onDelete: Cascade)

  @@unique([roleId, resourceActionId])
  @@map("role_permissions")
}

model UserPermissionOverride {
  id               String  @id @default(uuid())
  userId           String  @map("user_id")
  resourceActionId String  @map("resource_action_id")
  allowed          Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceAction ResourceAction @relation(fields: [resourceActionId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceActionId])
  @@map("user_permission_overrides")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String  @id @default(uuid())
  userId     String  @map("user_id")
  action     String
  resource   String
  resourceId String? @map("resource_id")
  metadata   Json?
  ipAddress  String? @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// ─── Module: Development — Projects ──────────────────────────────────────────

model Project {
  id               String         @id @default(uuid())
  organizationId   String         @map("organization_id")
  name             String
  code             String
  description      String?
  controlLevel     ControlLevel   @map("control_level")
  deploymentType   DeploymentType @map("deployment_type")
  status           ProjectStatus  @default(PLANNING)
  priority         Priority       @default(MEDIUM)
  hasSourceCode    Boolean        @default(false) @map("has_source_code")
  repositoryUrl    String?        @map("repository_url")
  sourceCodePath   String?        @map("source_code_path")
  responsibleUserId String?       @map("responsible_user_id")
  notes            String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization     Organization      @relation(fields: [organizationId], references: [id])
  responsibleUser  User?             @relation("ProjectResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  environments     ProjectEnvironment[]
  credentials      ProjectCredential[]
  projectRoles     ProjectRole[]
  departmentUsages DepartmentUsage[]
  techStack        TechStack[]
  sourceRelations  ProjectRelation[] @relation("ProjectRelationSource")
  targetRelations  ProjectRelation[] @relation("ProjectRelationTarget")
  documents        ProjectDocument[]
  changeRequests   ChangeRequest[]
  databases        Database[]
  domains          Domain[]
  supportTickets   SupportTicket[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@map("projects")
}

model ProjectEnvironment {
  id        String          @id @default(uuid())
  projectId String          @map("project_id")
  type      EnvironmentType
  serverIp  String?         @map("server_ip")
  serverPort Int?           @map("server_port")
  url       String?
  uncPath   String?         @map("unc_path")
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  credentials ProjectCredential[]

  @@unique([projectId, type])
  @@index([projectId])
  @@map("project_environments")
}

model ProjectCredential {
  id             String         @id @default(uuid())
  projectId      String         @map("project_id")
  environmentId  String?        @map("environment_id")
  label          String
  type           CredentialType
  username       String?
  encryptedValue String         @map("encrypted_value")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment ProjectEnvironment? @relation(fields: [environmentId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("project_credentials")
}

model ProjectRole {
  id          String  @id @default(uuid())
  projectId   String  @map("project_id")
  roleName    String  @map("role_name")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_roles")
}

model DepartmentUsage {
  id               String  @id @default(uuid())
  projectId        String  @map("project_id")
  departmentId     String  @map("department_id")
  estimatedUsers   Int?    @map("estimated_users")
  contactPerson    String? @map("contact_person")
  notes            String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  @@unique([projectId, departmentId])
  @@index([projectId])
  @@map("department_usages")
}

model TechStack {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  category  TechStackCategory
  name      String
  version   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("tech_stacks")
}

model ProjectRelation {
  id              String             @id @default(uuid())
  sourceProjectId String             @map("source_project_id")
  targetProjectId String             @map("target_project_id")
  type            ProjectRelationType
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  sourceProject Project @relation("ProjectRelationSource", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  targetProject Project @relation("ProjectRelationTarget", fields: [targetProjectId], references: [id], onDelete: Restrict)

  @@unique([sourceProjectId, targetProjectId, type])
  @@index([sourceProjectId])
  @@index([targetProjectId])
  @@map("project_relations")
}

model ProjectDocument {
  id           String       @id @default(uuid())
  projectId    String       @map("project_id")
  title        String
  type         DocumentType
  filePath     String       @map("file_path")
  fileSize     Int?         @map("file_size")
  mimeType     String?      @map("mime_type")
  uploadedById String?      @map("uploaded_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@map("project_documents")
}

// ─── Module: Development — Change Requests ───────────────────────────────────

model ChangeRequest {
  id                    String              @id @default(uuid())
  projectId             String              @map("project_id")
  title                 String
  description           String?
  requestedById         String?             @map("requested_by_id")
  requesterName         String              @map("requester_name")
  requesterDepartmentId String?             @map("requester_department_id")
  type                  ChangeRequestType
  priority              Priority            @default(MEDIUM)
  status                ChangeRequestStatus @default(REQUESTED)
  assignedToId          String?             @map("assigned_to_id")
  rejectionReason       String?             @map("rejection_reason")
  completionNotes       String?             @map("completion_notes")
  startedAt             DateTime?           @map("started_at")
  completedAt           DateTime?           @map("completed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  project              Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy          User?                     @relation("ChangeRequestRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  requesterDepartment  Department?               @relation(fields: [requesterDepartmentId], references: [id], onDelete: SetNull)
  assignedTo           User?                     @relation("ChangeRequestAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments             ChangeRequestComment[]
  attachments          ChangeRequestAttachment[]

  @@index([projectId])
  @@index([status])
  @@index([assignedToId])
  @@map("change_requests")
}

model ChangeRequestComment {
  id              String @id @default(uuid())
  changeRequestId String @map("change_request_id")
  userId          String @map("user_id")
  content         String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([changeRequestId])
  @@map("change_request_comments")
}

model ChangeRequestAttachment {
  id              String  @id @default(uuid())
  changeRequestId String  @map("change_request_id")
  filePath        String  @map("file_path")
  fileName        String  @map("file_name")
  fileSize        Int?    @map("file_size")
  mimeType        String? @map("mime_type")
  uploadedById    String? @map("uploaded_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  changeRequest ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  uploadedBy    User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([changeRequestId])
  @@map("change_request_attachments")
}

// ─── Module: Development — Databases ─────────────────────────────────────────

model Database {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  projectId      String?           @map("project_id")
  name           String
  engine         DatabaseEngine
  version        String?
  serverIp       String?           @map("server_ip")
  port           Int?
  databaseName   String?           @map("database_name")
  managedBy      DatabaseManagedBy @map("managed_by")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization Organization        @relation(fields: [organizationId], references: [id])
  project      Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  credentials  DatabaseCredential[]

  @@index([organizationId])
  @@index([projectId])
  @@map("databases")
}

model DatabaseCredential {
  id             String  @id @default(uuid())
  databaseId     String  @map("database_id")
  label          String
  username       String
  encryptedValue String  @map("encrypted_value")
  accessLevel    String? @map("access_level")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  database Database @relation(fields: [databaseId], references: [id], onDelete: Cascade)

  @@index([databaseId])
  @@map("database_credentials")
}

// ─── Module: Infrastructure — Enums ──────────────────────────────────────────

enum ServerOS {
  WINDOWS_SERVER
  UBUNTU
  CENTOS
  DEBIAN
  RHEL
  OTHER

  @@map("server_os")
}

enum ServerType {
  PHYSICAL
  VIRTUAL
  CONTAINER

  @@map("server_type")
}

enum ServerStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
  DECOMMISSIONED

  @@map("server_status")
}

enum ServerProtocol {
  RDP
  SSH
  WEB_PANEL
  IPMI
  VNC
  OTHER

  @@map("server_protocol")
}

enum ServiceStatus {
  RUNNING
  STOPPED
  UNKNOWN

  @@map("service_status")
}

enum NetworkEquipmentType {
  SWITCH
  ROUTER
  ACCESS_POINT
  FIREWALL
  UPS
  OTHER

  @@map("network_equipment_type")
}

enum NetworkEquipmentStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE

  @@map("network_equipment_status")
}

enum NetworkProtocol {
  SSH
  WEB_PANEL
  SNMP
  OTHER

  @@map("network_protocol")
}

enum DomainType {
  INTERNAL
  PUBLIC

  @@map("domain_type")
}

// ─── Module: Infrastructure — Server Groups ───────────────────────────────────

model ServerGroup {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?
  parentId       String? @map("parent_id")
  sortOrder      Int     @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  parent       ServerGroup?  @relation("ServerGroupHierarchy", fields: [parentId], references: [id])
  children     ServerGroup[] @relation("ServerGroupHierarchy")
  servers      Server[]

  @@index([organizationId])
  @@map("server_groups")
}

// ─── Module: Infrastructure — Servers ────────────────────────────────────────

model Server {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  groupId        String?      @map("group_id")
  hostname       String
  displayName    String?      @map("display_name")
  description    String?
  ip             String
  secondaryIp    String?      @map("secondary_ip")
  os             ServerOS
  type           ServerType
  specs          Json?
  location       String?
  domain         String?
  status         ServerStatus @default(ACTIVE)
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  group        ServerGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  credentials  ServerCredential[]
  services     ServerService[]
  documents    ServerDocument[]
  domains      Domain[]
  supportTickets   SupportTicket[]

  @@index([organizationId])
  @@map("servers")
}

model ServerCredential {
  id             String         @id @default(uuid())
  serverId       String         @map("server_id")
  label          String
  protocol       ServerProtocol
  port           Int?
  username       String?
  encryptedValue String         @map("encrypted_value")
  domain         String?
  isDefault      Boolean        @default(false) @map("is_default")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("server_credentials")
}

model ServerService {
  id        String        @id @default(uuid())
  serverId  String        @map("server_id")
  name      String
  port      Int?
  protocol  String?
  status    ServiceStatus @default(UNKNOWN)
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("server_services")
}

model ServerDocument {
  id           String       @id @default(uuid())
  serverId     String       @map("server_id")
  title        String
  type         DocumentType
  filePath     String       @map("file_path")
  fileSize     Int?         @map("file_size")
  mimeType     String?      @map("mime_type")
  uploadedById String?      @map("uploaded_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  server     Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([serverId])
  @@map("server_documents")
}

// ─── Module: Infrastructure — Network Equipment ───────────────────────────────

model NetworkEquipment {
  id             String                 @id @default(uuid())
  organizationId String                 @map("organization_id")
  name           String
  type           NetworkEquipmentType
  brand          String?
  model          String?
  ip             String?
  location       String?
  managementUrl  String?                @map("management_url")
  totalPorts     Int?                   @map("total_ports")
  firmware       String?
  status         NetworkEquipmentStatus @default(ACTIVE)
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization Organization                 @relation(fields: [organizationId], references: [id])
  credentials  NetworkEquipmentCredential[]
  ports        NetworkEquipmentPort[]

  @@index([organizationId])
  @@map("network_equipment")
}

model NetworkEquipmentCredential {
  id             String          @id @default(uuid())
  equipmentId    String          @map("equipment_id")
  label          String
  protocol       NetworkProtocol
  port           Int?
  username       String?
  encryptedValue String          @map("encrypted_value")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  equipment NetworkEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("network_equipment_credentials")
}

model NetworkEquipmentPort {
  id          String @id @default(uuid())
  equipmentId String @map("equipment_id")
  portNumber  String @map("port_number")
  label       String?
  vlan        String?
  connectedTo String? @map("connected_to")
  status      String  @default("unknown")
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  equipment NetworkEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@map("network_equipment_ports")
}

// ─── Module: Infrastructure — Domains ────────────────────────────────────────

model Domain {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  name           String
  type           DomainType
  pointsTo       String?    @map("points_to")
  serverId       String?    @map("server_id")
  projectId      String?    @map("project_id")
  sslEnabled     Boolean    @default(false) @map("ssl_enabled")
  sslExpiresAt   DateTime?  @map("ssl_expires_at")
  registrar      String?
  expiresAt      DateTime?  @map("expires_at")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  server       Server?      @relation(fields: [serverId], references: [id], onDelete: SetNull)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("domains")
}

// ─── Module: Support — Enums ──────────────────────────────────────────────────

enum AssetType {
  DESKTOP
  LAPTOP
  PRINTER
  SCANNER
  MONITOR
  UPS
  PHONE
  TABLET
  OTHER

  @@map("asset_type")
}

enum AssetStatus {
  ACTIVE
  IN_REPAIR
  STORAGE
  DECOMMISSIONED
  LOST

  @@map("asset_status")
}

enum SupportTicketType {
  HARDWARE_REPAIR
  SOFTWARE_INSTALL
  ACCESS_REQUEST
  NETWORK_ISSUE
  PRINTER_ISSUE
  GENERAL_SUPPORT
  OTHER

  @@map("support_ticket_type")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  WAITING_USER
  RESOLVED
  CLOSED

  @@map("support_ticket_status")
}

enum MaintenanceLogType {
  PREVENTIVE
  CORRECTIVE
  CLEANING
  UPGRADE

  @@map("maintenance_log_type")
}

enum UserAccountType {
  DOMAIN_AD
  EMAIL
  VPN
  SYSTEM_ACCESS
  OTHER

  @@map("user_account_type")
}

enum UserAccountStatus {
  ACTIVE
  DISABLED
  EXPIRED

  @@map("user_account_status")
}

// ─── Module: Support — Asset ──────────────────────────────────────────────────

model Asset {
  id                   String      @id @default(uuid())
  organizationId       String      @map("organization_id")
  name                 String
  type                 AssetType
  brand                String?
  model                String?
  serialNumber         String?     @map("serial_number")
  assetTag             String?     @map("asset_tag")
  assignedToUser       String?     @map("assigned_to_user")
  assignedToDepartmentId String?   @map("assigned_to_department_id")
  status               AssetStatus @default(ACTIVE)
  purchaseDate         DateTime?   @map("purchase_date")
  warrantyExpires      DateTime?   @map("warranty_expires")
  specs                Json?
  location             String?
  notes                String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization       Organization    @relation(fields: [organizationId], references: [id])
  assignedDepartment Department?     @relation(fields: [assignedToDepartmentId], references: [id], onDelete: SetNull)
  supportTickets     SupportTicket[]
  maintenanceLogs    MaintenanceLog[]

  @@index([organizationId])
  @@index([status])
  @@map("assets")
}

// ─── Module: Support — Tickets ────────────────────────────────────────────────

model SupportTicket {
  id                    String              @id @default(uuid())
  organizationId        String              @map("organization_id")
  ticketNumber          String              @map("ticket_number")
  title                 String
  description           String?
  type                  SupportTicketType
  priority              Priority            @default(MEDIUM)
  status                SupportTicketStatus @default(OPEN)
  requestedByName       String              @map("requested_by_name")
  requestedByDepartmentId String?           @map("requested_by_department_id")
  assignedToId          String?             @map("assigned_to_id")
  assetId               String?             @map("asset_id")
  projectId             String?             @map("project_id")
  serverId              String?             @map("server_id")
  resolution            String?
  resolvedAt            DateTime?           @map("resolved_at")
  closedAt              DateTime?           @map("closed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  organization        Organization              @relation(fields: [organizationId], references: [id])
  requestedByDept     Department?               @relation(fields: [requestedByDepartmentId], references: [id], onDelete: SetNull)
  assignedTo          User?                     @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  asset               Asset?                    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  project             Project?                  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  server              Server?                   @relation(fields: [serverId], references: [id], onDelete: SetNull)
  comments            SupportTicketComment[]
  attachments         SupportTicketAttachment[]

  @@unique([organizationId, ticketNumber])
  @@index([organizationId])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model SupportTicketComment {
  id         String  @id @default(uuid())
  ticketId   String  @map("ticket_id")
  userId     String  @map("user_id")
  content    String
  isInternal Boolean @default(false) @map("is_internal")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")
  deletedAt DateTime?                 @map("deleted_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([ticketId])
  @@map("support_ticket_comments")
}

model SupportTicketAttachment {
  id           String  @id @default(uuid())
  ticketId     String  @map("ticket_id")
  filePath     String  @map("file_path")
  fileName     String  @map("file_name")
  fileSize     Int?    @map("file_size")
  mimeType     String? @map("mime_type")
  uploadedById String? @map("uploaded_by_id")

  createdAt DateTime @default(now()) @map("created_at")

  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User?         @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@map("support_ticket_attachments")
}

// ─── Module: Support — Maintenance & Accounts ─────────────────────────────────

model MaintenanceLog {
  id              String             @id @default(uuid())
  assetId         String             @map("asset_id")
  type            MaintenanceLogType
  description     String
  performedById   String?            @map("performed_by_id")
  performedAt     DateTime           @map("performed_at")
  nextMaintenanceAt DateTime?        @map("next_maintenance_at")
  notes           String?

  createdAt DateTime @default(now()) @map("created_at")

  asset       Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  performedBy User? @relation(fields: [performedById], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@map("maintenance_logs")
}

model UserAccount {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  fullName       String            @map("full_name")
  username       String
  domain         String?
  email          String?
  departmentId   String?           @map("department_id")
  accountType    UserAccountType   @map("account_type")
  status         UserAccountStatus @default(ACTIVE)
  createdDate    DateTime?         @map("created_date")
  expirationDate DateTime?         @map("expiration_date")
  notes          String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("user_accounts")
}
