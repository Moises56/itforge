# Database
DATABASE_URL="postgresql://itforge:itforge_dev@localhost:5432/itforge_db"

# MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin123"
MINIO_USE_SSL=false
MINIO_BUCKET="itforge-assets"

# Encryption (AES-256-GCM) — generate with: openssl rand -hex 32
ENCRYPTION_MASTER_KEY="your-64-char-hex-key-here"

# Session — generate with: openssl rand -hex 32
SESSION_SECRET="your-64-char-hex-key-here"

# App
NEXT_PUBLIC_APP_NAME="ITForge"
NODE_ENV="development"
