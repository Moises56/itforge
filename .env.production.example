# ─────────────────────────────────────────────────────────────────────────────
# ITForge — Production Environment Variables
# Copy this file to .env.production and fill in real values before deploying.
# NEVER commit .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
# Internal database credentials (used by both the docker-compose postgres
# service and the DATABASE_URL connection string below)
POSTGRES_USER=itforge
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=itforge_db

# Full connection string used by Prisma (points to the internal 'postgres' service)
DATABASE_URL="postgresql://itforge:CHANGE_ME_STRONG_PASSWORD@postgres:5432/itforge_db"

# ─── MinIO Object Storage ────────────────────────────────────────────────────
# Root credentials for the MinIO server (admin console + bucket init)
MINIO_ROOT_USER=itforge_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Credentials used by the Next.js app to access MinIO
# These should match the root credentials (or a dedicated service account)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=itforge_minio
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=itforge-assets

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM master key for credential encryption.
# Generate with: openssl rand -hex 32
# CRITICAL: Back this up securely. Losing it means losing all stored credentials.
ENCRYPTION_MASTER_KEY=REPLACE_WITH_64_HEX_CHARS_FROM_OPENSSL_RAND_HEX_32

# ─── Session ─────────────────────────────────────────────────────────────────
# Secret for signing session tokens.
# Generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_64_HEX_CHARS_FROM_OPENSSL_RAND_HEX_32

# ─── Application ─────────────────────────────────────────────────────────────
# Public URL where the app is accessible (used for redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://your-server-ip-or-domain

# Display name shown in the browser tab and emails
NEXT_PUBLIC_APP_NAME=ITForge

NODE_ENV=production
